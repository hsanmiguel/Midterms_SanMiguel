  "installCommand": "cd midterms_sanmiguel && npm install",
  "buildCommand": "cd midterms_sanmiguel && npm run build",
  "outputDirectory": "midterms_sanmiguel/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
